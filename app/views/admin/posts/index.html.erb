<div class="max-w-4xl mx-auto px-4 py-8">
  <div class="flex justify-between items-center mb-8">
    <h1 class="text-3xl font-bold text-gray-900">Admin - Blog Posts</h1>
    <%= button_link "New Post", new_admin_post_path %>
  </div>

  <% if @posts.any? %>
    <div class="space-y-8">
      <% @posts.each do |post| %>
        <%= card tag: :article, padding: :medium do %>
          <div class="flex justify-between items-start mb-4">
            <h2 class="text-xl font-semibold text-gray-900">
              <%= link_to post.title, admin_post_path(post), class: "hover:text-blue-600 transition-colors" %>
            </h2>
            <div class="flex items-center space-x-2">
              <span class="px-2 py-1 text-xs font-medium rounded-full <%= post_status_classes(post) %>">
                <%= post.status.humanize %>
              </span>
              <%= button_link "Edit", edit_admin_post_path(post), variant: :secondary, size: :small %>
              <%= button_link "Delete", admin_post_path(post), variant: :danger, size: :small, method: :delete, confirm: "Are you sure?" %>
            </div>
          </div>

          <% if post.excerpt.present? %>
            <p class="text-gray-600 mb-4"><%= post.excerpt %></p>
          <% end %>

          <div class="text-sm text-gray-500">
            Published <%= time_ago_in_words(post.created_at) %> ago
          </div>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <div class="text-center py-16">
      <h3 class="text-lg font-medium text-gray-900 mb-2">No posts yet</h3>
      <p class="text-gray-500 mb-6">Get started by creating your first blog post.</p>
      <%= button_link "Create First Post", new_admin_post_path %>
    </div>
  <% end %>
</div>