<div class="max-w-4xl mx-auto px-4 py-8">
  <div class="mb-8">
    <%= link_to "← Back to Post", admin_post_path(@post), class: "text-blue-600 hover:text-blue-800 font-medium" %>
  </div>

  <%= card padding: :large, header: "Edit Post" do %>

    <%= styled_form_with model: [:admin, @post], local: true, class: "space-y-6" do |form| %>
      <%= error_messages_for(@post) %>

      <%= form.text_field :title %>

      <%= form.text_area :excerpt, rows: 3, hint: "Optional - will auto-generate from content if left blank" %>

      <%= form.text_area :content, rows: 15 %>

      <%= form.select :status,
          options_for_select([
            ['Draft', 'draft'],
            ['Published', 'published']
          ], @post.status),
          {},
          { hint: "Drafts are only visible to admins" } %>

      <div class="flex justify-between">
        <%= button_link "Cancel", admin_post_path(@post), variant: :secondary %>
        <div class="space-x-3">
          <%= form.submit "Update Post" %>
        </div>
      </div>
    <% end %>
  <% end %>
</div>