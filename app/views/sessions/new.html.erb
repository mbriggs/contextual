<div class="mx-auto md:w-2/3 w-full">
  <h1 class="font-bold text-4xl">Sign in</h1>

  <%= styled_form_with url: session_url, class: "contents" do |form| %>
    <div class="my-5">
      <%= form.email_field :email_address, labeled: false, required: true, autofocus: true, autocomplete: "username", placeholder: "Enter your email address", value: params[:email_address] || @default_email %>
    </div>

    <div class="my-5">
      <%= form.password_field :password, labeled: false, required: true, autocomplete: "current-password", placeholder: "Enter your password", maxlength: 72, value: params[:password] || @default_password %>
    </div>

    <div class="col-span-6 sm:flex sm:items-center sm:gap-4">
      <div class="inline">
        <%= form.submit "Sign in", class: button_classes(full_width_mobile: true) %>
      </div>

      <div class="mt-4 text-sm text-gray-500 sm:mt-0">
        <%= link_to "Forgot password?", new_password_path, class: "text-gray-700 underline hover:no-underline" %>
      </div>
    </div>
  <% end %>
</div>
