<div class="max-w-3xl mx-auto px-4 py-8">
  <div class="mb-8">
    <%= link_to "← Back to Posts", posts_path, class: "text-blue-600 hover:text-blue-800 font-medium" %>
  </div>

  <article class="bg-white">
    <header class="mb-8">
      <div class="flex justify-between items-start mb-4">
        <h1 class="text-4xl font-bold text-gray-900"><%= @post.title %></h1>
        <% if admin_signed_in? %>
          <div class="flex items-center space-x-4">
            <span class="px-3 py-1 text-sm font-medium rounded-full <%= post_status_classes(@post) %>">
              <%= @post.status.humanize %>
            </span>
            <%= button_link "Edit", edit_admin_post_path(@post) %>
            <%= button_link "Delete", admin_post_path(@post), variant: :danger, method: :delete,
                confirm: "Are you sure you want to delete this post?" %>
          </div>
        <% end %>
      </div>

      <% if @post.excerpt.present? %>
        <p class="text-xl text-gray-600 mb-4"><%= @post.excerpt %></p>
      <% end %>

      <div class="text-sm text-gray-500 border-b border-gray-200 pb-4">
        Published <%= time_ago_in_words(@post.created_at) %> ago
        <% if @post.updated_at != @post.created_at %>
          • Updated <%= time_ago_in_words(@post.updated_at) %> ago
        <% end %>
      </div>
    </header>

    <div class="prose prose-lg max-w-none">
      <%= @post.content %>
    </div>
  </article>

  <% if @post.comments.approved.any? %>
    <section class="mt-12">
      <h3 class="text-2xl font-bold text-gray-900 mb-6">Comments</h3>
      <div class="space-y-6">
        <% @post.comments.approved.recent.each do |comment| %>
          <div class="bg-gray-50 rounded-lg p-6">
            <div class="flex justify-between items-start mb-3">
              <div class="font-medium text-gray-900"><%= comment.user.email_address %></div>
              <div class="text-sm text-gray-500"><%= time_ago_in_words(comment.created_at) %> ago</div>
            </div>
            <p class="text-gray-700"><%= simple_format(comment.content) %></p>
          </div>
        <% end %>
      </div>
    </section>
  <% end %>
</div>