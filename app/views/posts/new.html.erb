<div class="max-w-4xl mx-auto px-4 py-8">
  <div class="mb-8">
    <%= link_to "← Back to Posts", posts_path, class: "text-blue-600 hover:text-blue-800 font-medium" %>
  </div>

  <%= card padding: :large, header: "Create New Post" do %>

    <%= form_with model: @post, local: true, class: "space-y-6" do |form| %>
      <%= error_messages_for(@post) %>

      <div>
        <%= form.label :title, class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= form.text_field :title, class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
      </div>

      <div>
        <%= form.label :excerpt, class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= form.text_area :excerpt, rows: 3, class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
        <p class="text-sm text-gray-500 mt-1">Optional - will auto-generate from content if left blank</p>
      </div>

      <div>
        <%= form.label :content, class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= form.text_area :content, rows: 15, class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
      </div>

      <div>
        <%= form.label :status, class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= form.select :status,
            options_for_select([
              ['Draft', 'draft'],
              ['Published', 'published']
            ], @post.status),
            {},
            { class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500" } %>
        <p class="text-sm text-gray-500 mt-1">Drafts are only visible to admins</p>
      </div>

      <div class="flex justify-between">
        <%= link_to "Cancel", posts_path, class: "bg-gray-300 hover:bg-gray-400 text-gray-800 font-medium py-2 px-4 rounded-lg transition-colors" %>
        <%= form.submit "Create Post", class: "bg-blue-600 hover:bg-blue-700 text-white font-medium py-2 px-6 rounded-lg transition-colors" %>
      </div>
    <% end %>
  <% end %>
</div>