#!/usr/bin/env ruby
require "fileutils"

APP_ROOT = File.expand_path("..", __dir__)

def system!(*args)
  system(*args, exception: true)
end

FileUtils.chdir APP_ROOT do
  # This script sets up your development environment automatically.
  # Run with --skip-server to avoid starting the dev server afterwards.

  puts "== Checking system dependencies =="
  system!("command -v brew > /dev/null || (echo 'Homebrew is required. Install from https://brew.sh' && exit 1)")
  
  puts "\n== Installing Homebrew dependencies =="
  system!("brew bundle check || brew bundle install")

  puts "\n== Installing Ruby dependencies =="
  system("bundle check") || system!("bundle install")

  puts "\n== Preparing databases =="
  system! "bin/rails db:prepare"
  
  puts "\n== Running quality tools =="
  system! "bundle exec rubocop -A"
  system! "bin/rails test"

  puts "\n== Cleaning up =="
  system! "bin/rails log:clear tmp:clear"

  puts "\n== Setup complete! =="
  puts "See docs/SETUP.md for manual setup instructions"
  puts "See docs/DEVELOPING.md for development workflow"

  unless ARGV.include?("--skip-server")
    puts "\n== Starting development server =="
    puts "Press Ctrl+C to stop the server"
    STDOUT.flush
    exec "bin/dev"
  end
end
